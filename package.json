{
  "name": "zenodo-mcp-server",
  "version": "0.1.0",
  "description": "MCP server for querying and managing Zenodo repositories",
  "type": "module",
  "main": "build/src/index.js",
  "bin": {
    "zenodo-mcp-server": "./build/src/index.js"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "test": "npm run build && node --test build/test/*.test.js",
    "test:coverage": "npm run build && c8 --reporter=text --reporter=lcov --reporter=json-summary node --test build/test/*.test.js",
    "coverage": "npm run test:coverage"
  },
  "keywords": [
    "mcp",
    "zenodo",
    "repository",
    "open-science"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1"
  },
  "devDependencies": {
    "@types/node": "^20.19.37",
    "c8": "^10.1.3",
    "typescript": "^5.9.3"
  }
}
